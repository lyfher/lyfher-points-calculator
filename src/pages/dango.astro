---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';

const project = projects.find(p => p.slug === 'dango')!;
const scenarios = project.scenarios;
---

<Layout title="Dango Points Calculator — Lyfher" description={project.description}>

  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <style>
    .d-serif { font-family: 'DM Serif Display', Georgia, serif; }
  </style>

  <!-- Hero gradient -->
  <div class="rounded-3xl mb-5 overflow-hidden" style="background: linear-gradient(135deg, #D88E96 0%, #EDE4B9 50%, #FFF2E2 100%);">
    <div class="px-6 py-8 flex flex-col sm:flex-row items-center gap-6">
      <!-- Left: text -->
      <div class="flex-1 text-center sm:text-left">
        <a href="/" class="text-sm mb-3 inline-block" style="color:#302723aa;">← Back</a>
        <h1 class="text-5xl font-bold d-serif leading-tight" style="color:#302723;">Dango</h1>
        <p class="mt-2 text-sm" style="color:#302723bb;"
           data-en={project.description} data-es={project.descriptionEs}>
          {project.description}
        </p>
        <div class="flex items-center gap-2 mt-4 justify-center sm:justify-start">
          <div class="w-4 h-4 rounded-full" style="background:#DD3756;"></div>
          <div class="w-4 h-4 rounded-full" style="background:#FFF2E2; border:1px solid #C4B7BA;"></div>
          <div class="w-4 h-4 rounded-full" style="background:#AFB244;"></div>
        </div>
      </div>
      <!-- Right: logo -->
      <div class="flex-shrink-0">
        <img src="/logos/dangologo.jpg" alt="Dango" class="w-28 h-28 rounded-2xl object-cover shadow-lg" style="border: 3px solid #FFF2E2;" />
      </div>
    </div>
  </div>

  <!-- Inputs row -->
  <div class="flex flex-wrap gap-3 mb-5 items-end">
    <div class="flex-1 min-w-40">
      <label class="block text-xs mb-1.5 font-medium" style="color:#C4B7BA;" for="my-points"
             data-en="My total points" data-es="Mis puntos totales">My total points</label>
      <input
        type="number" id="my-points" placeholder="0" min="0" max="1000000"
        class="w-full rounded-2xl px-4 py-3 text-xl font-bold focus:outline-none transition-all"
        style="background:#2a1f19; border:1px solid #4a3428; color:#FFF2E2;"
        onfocus="this.style.borderColor='#DD3756'; this.style.boxShadow='0 0 0 3px #DD375620';"
        onblur="this.style.borderColor='#4a3428'; this.style.boxShadow='none';"
      />
    </div>

    <div class="flex-1 min-w-52">
      <label class="block text-xs mb-1.5 font-medium" style="color:#C4B7BA;">
        <span data-en="My price per point ($)" data-es="Mi precio por punto ($)">My price per point ($)</span>
      </label>
      <div class="flex items-center gap-3">
        <input type="range" id="custom-price-range" min="0" max={String(project.sliderMax)} step="0.1" value="0"
          class="flex-1 cursor-pointer" style="accent-color:#DD3756;" />
        <input type="number" id="custom-price" placeholder="0.00" min="0" step="0.01"
          class="w-20 rounded-2xl px-3 py-3 text-center font-bold focus:outline-none transition-all"
          style="background:#2a1f19; border:1px solid #4a3428; color:#FFF2E2;"
          onfocus="this.style.borderColor='#DD3756';"
          onblur="this.style.borderColor='#4a3428';" />
      </div>
    </div>

    <!-- Total pill -->
    <div class="rounded-2xl px-6 py-3 text-center" style="background: linear-gradient(135deg, #DD375620, #AFB24415); border:1px solid #DD375640;">
      <p class="text-xs mb-1 font-medium" style="color:#C4B7BA;"
         data-en="Your value" data-es="Tu valor">Your value</p>
      <p id="custom-total" class="text-2xl font-bold d-serif" style="color:#FFF2E2;">$0.00</p>
    </div>
  </div>

  <!-- Main grid -->
  <div class="grid gap-4 lg:grid-cols-5">

    <!-- Scenarios -->
    <div class="lg:col-span-3 rounded-3xl overflow-hidden" style="background:#2a1f19; border:1px solid #4a3428;">
      <!-- Top gradient bar -->
      <div class="h-1.5" style="background:linear-gradient(90deg, #DD3756, #EDE4B9, #AFB244);"></div>
      <div class="p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest mb-5" style="color:#7a6058;"
            data-en="Price scenarios" data-es="Escenarios de precio">Price scenarios</h2>
        <table class="w-full">
          <thead>
            <tr class="text-xs uppercase" style="color:#5a4038; border-bottom:1px solid #4a342860;">
              <th class="text-left pb-3 pr-4" data-en="Scenario" data-es="Escenario">Scenario</th>
              <th class="text-right pb-3 pr-4" data-en="Price / pt" data-es="Precio / pt">Price / pt</th>
              <th class="text-right pb-3" data-en="Your value" data-es="Tu valor">Your value</th>
            </tr>
          </thead>
          <tbody>
            {scenarios.map((s, i) => (
              <tr style="border-bottom:1px solid #4a342830;">
                <td class="py-4 pr-4 font-semibold text-sm" style="color:#FFF2E2;">
                  <span class="mr-2 text-base">{s.emoji}</span>
                  <span data-en={s.label} data-es={s.labelEs}>{s.label}</span>
                </td>
                <td class="py-4 pr-4 text-right font-mono text-sm" style="color:#C4B7BA;">
                  ${s.pricePerPoint.toFixed(2)}
                </td>
                <td id={`scenario-val-${i}`}
                  class={`py-4 text-right text-xl font-bold d-serif`}
                  style={i===0 ? 'color:#f87171;' : i===1 ? 'color:#EDE4B9;' : 'color:#AFB244;'}>
                  $0.00
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right column -->
    <div class="lg:col-span-2 flex flex-col gap-4">

      <!-- Referral card -->
      <div class="rounded-3xl p-6 flex-1 flex flex-col justify-between" style="background: linear-gradient(135deg, #3d1e28, #2a1f19); border:1px solid #DD375640;">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color:#DD3756;"
             data-en="Referral link" data-es="Link de referido">Referral link</p>
          <p class="text-sm font-medium mb-5" style="color:#FFF2E2aa;"
             data-en={project.referralBenefit} data-es={project.referralBenefitEs}>
            {project.referralBenefit}
          </p>
        </div>
        <a href={project.referralLink} target="_blank" rel="noopener noreferrer"
          class="block text-center font-bold py-3 rounded-2xl transition-all hover:opacity-90 d-serif text-lg"
          style="background:linear-gradient(135deg, #DD3756, #c02040); color:#FFF2E2; letter-spacing:0.02em;"
          data-en={`Sign up on ${project.name} →`}
          data-es={`Regístrate en ${project.name} →`}>
          Sign up on {project.name} →
        </a>
      </div>

      <!-- Tips card -->
      <div class="rounded-3xl p-5" style="background:#2a1f19; border:1px solid #4a3428;">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color:#7a6058;"
           data-en="Tips" data-es="Consejos">Tips</p>
        <ul class="space-y-2 text-xs" style="color:#C4B7BA;">
          <li data-en="• Stay active every day" data-es="• Mantén actividad constante">• Stay active every day</li>
          <li data-en="• Increase volume gradually" data-es="• Aumenta el volumen gradualmente">• Increase volume gradually</li>
          <li data-en="• Referral link = extra bonuses" data-es="• Link de referido = bonificaciones extra">• Referral link = extra bonuses</li>
          <li data-en="• Watch for season multipliers" data-es="• Atento a multiplicadores de temporada">• Watch for season multipliers</li>
        </ul>
      </div>
    </div>

  </div>

</Layout>

<script define:vars={{ projectScenarios: scenarios, projectSliderMax: project.sliderMax }}>
  function fmt(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function update() {
    const pts = parseFloat(document.getElementById('my-points')?.value) || 0;
    const price = parseFloat(document.getElementById('custom-price')?.value) || 0;
    document.getElementById('custom-total').textContent = fmt(pts * price);
    projectScenarios.forEach((s, i) => {
      const el = document.getElementById(`scenario-val-${i}`);
      if (el) el.textContent = fmt(pts * s.pricePerPoint);
    });
  }
  const range = document.getElementById('custom-price-range');
  const price = document.getElementById('custom-price');
  range?.addEventListener('input', () => { price.value = range.value; update(); });
  price?.addEventListener('input', () => { range.value = Math.min(parseFloat(price.value)||0, projectSliderMax); update(); });
  const ptsInput = document.getElementById('my-points');
  ptsInput?.addEventListener('input', () => {
    if (parseFloat(ptsInput.value) > 1000000) ptsInput.value = '1000000';
    update();
  });
</script>
