---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';

const project = projects.find(p => p.slug === 'dango')!;
const scenarios = project.scenarios;
---

<Layout title="Dango Points Calculator — Lyfher" description={project.description}>

  <!-- Google Font: DM Serif Display (similar to Exposure) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <style>
    .dango-serif { font-family: 'DM Serif Display', Georgia, serif; }
    .dango-bg { background-color: #302723; }
    .dango-bg-dark { background-color: #1e1710; }
    .dango-cream { color: #FFF2E2; }
    .dango-muted { color: #C4B7BA; }
    .dango-border { border-color: #4a3428; }
    .dango-red { color: #DD3756; }
    .dango-green { color: #AFB244; }
  </style>

  <!-- Hero -->
  <div class="rounded-2xl p-5 mb-4 border dango-bg dango-border"
       style="background: linear-gradient(135deg, #DD375618 0%, #30272300 60%); border-color: #DD375640;">
    <div class="flex items-center gap-3">
      <a href="/" class="text-gray-500 hover:text-gray-300 transition-colors text-sm mr-1">←</a>
      <img src="/logos/dangologo.jpg" alt="Dango" class="w-10 h-10 rounded-xl object-cover" />
      <div>
        <h1 class="text-2xl font-bold dango-cream dango-serif">#DANGO</h1>
        <p class="text-xs mt-0.5 dango-muted"
           data-en={project.description} data-es={project.descriptionEs}>
          {project.description}
        </p>
      </div>
      <!-- Tres bolitas decorativas -->
      <div class="ml-auto hidden sm:flex items-center gap-1.5">
        <div class="w-5 h-5 rounded-full" style="background:#DD3756"></div>
        <div class="w-5 h-5 rounded-full" style="background:#FFF2E2"></div>
        <div class="w-5 h-5 rounded-full" style="background:#AFB244"></div>
      </div>
    </div>
  </div>

  <!-- Inputs row -->
  <div class="flex flex-wrap gap-3 mb-4 items-end">
    <div class="flex-1 min-w-40">
      <label class="block text-xs mb-1 dango-muted" for="my-points"
             data-en="My total points" data-es="Mis puntos totales">My total points</label>
      <input
        type="number" id="my-points" placeholder="0" min="0" max="1000000"
        class="w-full rounded-xl px-4 py-2.5 text-xl font-bold focus:outline-none transition-colors dango-cream"
        style="background:#1e1710; border: 1px solid #4a3428;"
        onfocus="this.style.borderColor='#DD375680'"
        onblur="this.style.borderColor='#4a3428'"
      />
    </div>

    <div class="flex-1 min-w-52">
      <label class="block text-xs mb-1 dango-muted">
        <span data-en="My price per point ($)" data-es="Mi precio por punto ($)">My price per point ($)</span>
      </label>
      <div class="flex items-center gap-2">
        <input type="range" id="custom-price-range" min="0" max={String(project.sliderMax)} step="0.1" value="0"
          class="flex-1 cursor-pointer" style="accent-color: #DD3756" />
        <input type="number" id="custom-price" placeholder="0.00" min="0" step="0.01"
          class="w-20 rounded-xl px-3 py-2.5 text-center font-bold focus:outline-none transition-colors dango-cream"
          style="background:#1e1710; border: 1px solid #4a3428;"
          onfocus="this.style.borderColor='#DD375680'"
          onblur="this.style.borderColor='#4a3428'" />
      </div>
    </div>

    <!-- Total pill -->
    <div class="rounded-xl px-5 py-2.5 text-center border" style="border-color: #DD375640; background: #DD375615">
      <p class="text-xs mb-0.5 dango-muted"
         data-en="Your value" data-es="Tu valor">Your value</p>
      <p id="custom-total" class="text-xl font-bold dango-cream dango-serif">$0.00</p>
    </div>
  </div>

  <!-- Main grid -->
  <div class="grid gap-4 lg:grid-cols-5">

    <!-- Scenarios -->
    <div class="lg:col-span-3 rounded-2xl overflow-hidden border dango-bg dango-border">
      <div class="h-1 w-full" style="background: linear-gradient(90deg, #DD3756, #AFB244)"></div>
      <div class="p-5">
        <h2 class="text-xs font-semibold uppercase tracking-wider mb-4 dango-muted"
            data-en="Price scenarios" data-es="Escenarios de precio">Price scenarios</h2>
        <table class="w-full">
          <thead>
            <tr class="text-xs uppercase" style="color:#4a3428; border-bottom: 1px solid #4a3428;">
              <th class="text-left pb-2 pr-4" data-en="Scenario" data-es="Escenario">Scenario</th>
              <th class="text-right pb-2 pr-4" data-en="Price / pt" data-es="Precio / pt">Price / pt</th>
              <th class="text-right pb-2" data-en="Your value" data-es="Tu valor">Your value</th>
            </tr>
          </thead>
          <tbody>
            {scenarios.map((s, i) => (
              <tr style="border-bottom: 1px solid #4a342840;">
                <td class="py-3.5 pr-4 font-semibold text-sm dango-cream">
                  <span class="mr-2">{s.emoji}</span>
                  <span data-en={s.label} data-es={s.labelEs}>{s.label}</span>
                </td>
                <td class="py-3.5 pr-4 text-right font-mono text-sm dango-muted">
                  ${s.pricePerPoint.toFixed(2)}
                </td>
                <td id={`scenario-val-${i}`}
                  class={`py-3.5 text-right text-lg font-bold dango-serif ${i===0?'text-red-400':i===1?'text-yellow-300':'dango-green'}`}>
                  $0.00
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Referral + Tips -->
    <div class="lg:col-span-2 flex flex-col gap-3">
      <div class="rounded-2xl p-5 border flex-1 dango-bg dango-border">
        <p class="text-xs font-semibold uppercase tracking-wider mb-1 dango-red"
           data-en="Referral link" data-es="Link de referido">Referral link</p>
        <p class="text-sm font-medium mb-4 dango-cream"
           data-en={project.referralBenefit} data-es={project.referralBenefitEs}>
          {project.referralBenefit}
        </p>
        <a href={project.referralLink} target="_blank" rel="noopener noreferrer"
          class="block text-center font-bold py-2.5 rounded-xl transition-opacity hover:opacity-90 dango-serif"
          style="background: #DD3756; color: #FFF2E2;"
          data-en={`Sign up on ${project.name} →`}
          data-es={`Regístrate en ${project.name} →`}>
          Sign up on {project.name} →
        </a>
      </div>

      <div class="rounded-2xl p-4 border dango-bg dango-border">
        <p class="text-xs font-semibold uppercase tracking-wider mb-2 dango-muted"
           data-en="Tips" data-es="Consejos">Tips</p>
        <ul class="space-y-1.5 text-xs dango-muted">
          <li data-en="• Stay active every day" data-es="• Mantén actividad constante">• Stay active every day</li>
          <li data-en="• Increase volume gradually" data-es="• Aumenta el volumen gradualmente">• Increase volume gradually</li>
          <li data-en="• Referral link = extra bonuses" data-es="• Link de referido = bonificaciones extra">• Referral link = extra bonuses</li>
          <li data-en="• Watch for season multipliers" data-es="• Atento a multiplicadores de temporada">• Watch for season multipliers</li>
        </ul>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ projectScenarios: scenarios, projectSliderMax: project.sliderMax }}>
  function fmt(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function update() {
    const pts = parseFloat(document.getElementById('my-points')?.value) || 0;
    const price = parseFloat(document.getElementById('custom-price')?.value) || 0;
    document.getElementById('custom-total').textContent = fmt(pts * price);
    projectScenarios.forEach((s, i) => {
      const el = document.getElementById(`scenario-val-${i}`);
      if (el) el.textContent = fmt(pts * s.pricePerPoint);
    });
  }
  const range = document.getElementById('custom-price-range');
  const price = document.getElementById('custom-price');
  range?.addEventListener('input', () => { price.value = range.value; update(); });
  price?.addEventListener('input', () => { range.value = Math.min(parseFloat(price.value)||0, projectSliderMax); update(); });
  const ptsInput = document.getElementById('my-points');
  ptsInput?.addEventListener('input', () => {
    if (parseFloat(ptsInput.value) > 1000000) ptsInput.value = '1000000';
    update();
  });
</script>
