---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import type { Project } from '../data/projects';
import ProjectLogo from '../components/ProjectLogo.astro';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { proyecto: project.slug },
    props: { project },
  }));
}

interface Props { project: Project; }
const { project } = Astro.props;
const accent = project.accentHex;
---

<Layout title={`${project.name} Points Calculator — Lyfher`} description={project.description}>

  <!-- Hero with accent glow -->
  <div
    class="rounded-2xl p-5 mb-4 border"
    style={`border-color: ${accent}30; background: linear-gradient(135deg, ${accent}12 0%, transparent 60%);`}
  >
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/" class="text-gray-600 hover:text-gray-400 transition-colors text-sm mr-1">←</a>
        <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="lg" />
        <div>
          <h1 class="text-2xl font-bold text-white">{project.name}</h1>
          <p class="text-gray-500 text-xs mt-0.5" data-en={project.description} data-es={project.descriptionEs}>
            {project.description}
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Points input row -->
  <div class="flex flex-wrap gap-3 mb-4 items-end">
    <!-- My points -->
    <div class="flex-1 min-w-48">
      <label class="block text-xs text-gray-500 mb-1 uppercase tracking-wider" for="my-points"
             data-en="Your points" data-es="Tus puntos">Your points</label>
      <input
        type="number" id="my-points" placeholder="0" min="0" max="100000000"
        class="w-full bg-gray-900 border border-gray-800 rounded-xl px-4 py-3 text-white text-xl font-bold placeholder-gray-700 focus:outline-none transition-colors"
        onfocus={`this.style.borderColor='${accent}80'`}
        onblur="this.style.borderColor=''"
      />
    </div>

    <!-- Total pool (editable) -->
    <div class="flex-1 min-w-48">
      <label class="block text-xs text-gray-500 mb-1 uppercase tracking-wider" for="total-pool"
             data-en="Total points pool (estimated)" data-es="Pool total de puntos (estimado)">Total points pool (estimated)</label>
      <input
        type="number" id="total-pool" min="1"
        placeholder={String(project.totalPointsPool ?? 10000000)}
        value={String(project.totalPointsPool ?? '')}
        class="w-full bg-gray-900 border border-dashed border-gray-700 rounded-xl px-4 py-3 text-white text-xl font-bold placeholder-gray-600 focus:outline-none transition-colors"
        onfocus={`this.style.borderColor='${accent}80'`}
        onblur="this.style.borderColor=''"
      />
    </div>

    <!-- Share % -->
    <div class="rounded-xl px-4 py-3 text-center border min-w-28" style={`border-color: ${accent}40; background: ${accent}12`}>
      <p class="text-xs mb-0.5" style={`color: ${accent}99`} data-en="Your share" data-es="Tu share">Your share</p>
      <p id="share-pct" class="text-sm font-bold font-mono" style={`color: ${accent}`}>0.0000%</p>
    </div>
  </div>

  <!-- Main grid: Matrix | Referral -->
  <div class="grid gap-4 lg:grid-cols-3">

    <!-- FDV × Allocation Matrix -->
    <div class="lg:col-span-2 bg-gray-900 rounded-2xl overflow-hidden border border-gray-800">
      <div class="h-1 w-full" style={`background: linear-gradient(90deg, ${accent}, ${accent}44)`}></div>
      <div class="p-5">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4"
            data-en="Airdrop Calculator" data-es="Calculadora de Airdrop">Airdrop Calculator</h2>
        <div>
          <table class="w-full text-sm" id="fdv-matrix">
            <thead>
              <tr class="uppercase border-b border-gray-800 text-gray-600">
                <th class="text-left pb-2 pr-2 font-semibold text-xs" data-en="Alloc %" data-es="Asig %">Alloc %</th>
                {['$50M','$100M','$250M','$500M','$1B','$2B'].map(fdv => (
                  <th class="text-right pb-2 px-3 font-semibold text-xs whitespace-nowrap">{fdv}</th>
                ))}
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-800" id="matrix-body">
              {[10, 15, 20, 25, 30].map(alloc => (
                <tr>
                  <td class="py-3 pr-2 font-bold" style={`color: ${accent}`}>{alloc}%</td>
                  {[
                    {fdv: 50_000_000,    group:'bear'},
                    {fdv: 100_000_000,   group:'bear'},
                    {fdv: 250_000_000,   group:'normal'},
                    {fdv: 500_000_000,   group:'normal'},
                    {fdv: 1_000_000_000, group:'bull'},
                    {fdv: 2_000_000_000, group:'bull'},
                  ].map(col => (
                    <td class="py-4 px-3 text-right font-mono matrix-cell"
                        data-alloc={alloc} data-fdv={col.fdv} data-group={col.group}>
                      —
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {project.totalPointsPool && (
          <p class="text-xs text-gray-700 mt-3 text-right font-mono">
            Total points pool: {project.totalPointsPool.toLocaleString('en-US')}
          </p>
        )}
      </div>
    </div>

    <!-- Referral + Tips -->
    <div class="lg:col-span-1 flex flex-col gap-3">
      <div class="rounded-2xl p-5 border flex-1" style={`border-color: ${accent}30; background: ${accent}12`}>
        <p class="text-xs font-semibold uppercase tracking-wider mb-1" style={`color: ${accent}`}
           data-en="Referral link" data-es="Link de referido">Referral link</p>
        <p class="text-white text-sm font-medium mb-4"
           data-en={project.referralBenefit} data-es={project.referralBenefitEs}>
          {project.referralBenefit}
        </p>
        <a href={project.referralLink} target="_blank" rel="noopener noreferrer"
          class="block text-center text-white font-bold py-2.5 rounded-xl transition-opacity hover:opacity-90"
          style={`background: ${accent}`}
          data-en={`Sign up on ${project.name} →`}
          data-es={`Regístrate en ${project.name} →`}>
          Sign up on {project.name} →
        </a>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-2"
           data-en="Tips" data-es="Consejos">Tips</p>
        <ul class="space-y-1.5 text-gray-500 text-xs">
          <li data-en="• Stay active every day" data-es="• Mantén actividad constante">• Stay active every day</li>
          <li data-en="• Increase volume gradually" data-es="• Aumenta el volumen gradualmente">• Increase volume gradually</li>
          <li data-en="• Referral link = extra bonuses" data-es="• Link de referido = bonificaciones extra">• Referral link = extra bonuses</li>
          <li data-en="• Watch for season multipliers" data-es="• Atento a multiplicadores de temporada">• Watch for season multipliers</li>
        </ul>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ defaultPool: project.totalPointsPool ?? 10000000 }}>
  function fmtMoney(n) {
    if (n >= 1_000_000) return '$' + (n / 1_000_000).toFixed(2) + 'M';
    if (n >= 1_000)     return '$' + (n / 1_000).toFixed(1) + 'K';
    return '$' + n.toFixed(2);
  }

  function cellColor(val, minVal, maxVal) {
    if (maxVal === minVal) return '#facc15';
    const t = (val - minVal) / (maxVal - minVal); // 0 = bear, 1 = bull
    if (t < 0.33) return '#f87171';  // red
    if (t < 0.66) return '#facc15';  // yellow
    return '#4ade80';                 // green
  }

  function update() {
    const pts  = parseFloat(document.getElementById('my-points')?.value) || 0;
    const pool = parseFloat(document.getElementById('total-pool')?.value) || defaultPool;

    // Share %
    const shareEl = document.getElementById('share-pct');
    if (shareEl) {
      const pct = pool > 0 ? (pts / pool) * 100 : 0;
      shareEl.textContent = pct.toFixed(4) + '%';
    }

    // Matrix cells
    const cells = document.querySelectorAll('.matrix-cell');
    if (pts === 0) {
      cells.forEach(cell => {
        cell.textContent = '—';
        cell.style.color = '#4b5563';
        cell.style.fontWeight = '400';
      });
      return;
    }
    // Calculate all values first to find min/max
    const values = Array.from(cells).map(cell => {
      const alloc = parseFloat(cell.dataset.alloc) / 100;
      const fdv   = parseFloat(cell.dataset.fdv);
      return (pts / pool) * alloc * fdv;
    });
    const minVal = Math.min(...values);
    const maxVal = Math.max(...values);
    cells.forEach((cell, i) => {
      const val = values[i];
      cell.textContent = fmtMoney(val);
      cell.style.color = cellColor(val, minVal, maxVal);
      cell.style.fontWeight = '600';
    });
  }

  const ptsInput = document.getElementById('my-points');
  ptsInput?.addEventListener('input', () => {
    if (parseFloat(ptsInput.value) > 100_000_000) ptsInput.value = '100000000';
    update();
  });
  document.getElementById('total-pool')?.addEventListener('input', update);

</script>
