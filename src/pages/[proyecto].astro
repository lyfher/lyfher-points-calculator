---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import type { Project } from '../data/projects';
import ProjectLogo from '../components/ProjectLogo.astro';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { proyecto: project.slug },
    props: { project },
  }));
}

interface Props { project: Project; }
const { project } = Astro.props;
const accent = project.accentHex;
---

<Layout title={`${project.name} Points Calculator — Lyfher`} description={project.description}>

  <!-- Hero with accent glow -->
  <div
    class="rounded-2xl p-5 mb-4 border"
    style={`border-color: ${accent}30; background: linear-gradient(135deg, ${accent}12 0%, transparent 60%);`}
  >
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <a href="/" class="text-gray-600 hover:text-gray-400 transition-colors text-sm mr-1">←</a>
        <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="lg" />
        <div>
          <h1 class="text-2xl font-bold text-white">{project.name}</h1>
          <p class="text-gray-500 text-xs mt-0.5" data-en={project.description} data-es={project.descriptionEs}>
            {project.description}
          </p>
        </div>
      </div>
      <!-- $/pt quick reference -->
      <div class="hidden sm:flex gap-3 text-center">
        {project.scenarios.map((s, i) => (
          <div>
            <div class="text-xs text-gray-600">{s.emoji}</div>
            <div class={`text-sm font-bold ${i===0?'text-red-400':i===1?'text-yellow-400':'text-green-400'}`}>
              ${s.pricePerPoint}
            </div>
            <div class="text-xs text-gray-600" style={`color: ${accent}99`}>/pt</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Inputs row -->
  <div class="flex flex-wrap gap-3 mb-4 items-end">
    <div class="flex-1 min-w-40">
      <label class="block text-xs text-gray-500 mb-1" for="my-points"
             data-en="My total points" data-es="Mis puntos totales">My total points</label>
      <input
        type="number" id="my-points" placeholder="0" min="0"
        class="w-full bg-gray-900 border border-gray-800 rounded-xl px-4 py-2.5 text-white text-xl font-bold placeholder-gray-700 focus:outline-none transition-colors"
        style={`--tw-ring-color: ${accent}; outline: none;`}
        onfocus={`this.style.borderColor='${accent}80'`}
        onblur="this.style.borderColor=''"
      />
    </div>

    <div class="flex-1 min-w-52">
      <label class="block text-xs text-gray-500 mb-1">
        <span data-en="My price per point ($)" data-es="Mi precio por punto ($)">My price per point ($)</span>
      </label>
      <div class="flex items-center gap-2">
        <input type="range" id="custom-price-range" min="0" max={String(project.sliderMax)} step={project.sliderMax <= 1 ? "0.01" : "0.1"} value="0"
          class="flex-1 cursor-pointer" style={`accent-color: ${accent}`} />
        <input type="number" id="custom-price" placeholder="0.00" min="0" step="0.01"
          class="w-20 bg-gray-900 border border-gray-800 rounded-xl px-3 py-2.5 text-white text-center font-bold focus:outline-none transition-colors"
          onfocus={`this.style.borderColor='${accent}80'`}
          onblur="this.style.borderColor=''" />
      </div>
    </div>

    <!-- Total pill -->
    <div class="rounded-xl px-5 py-2.5 text-center border" style={`border-color: ${accent}40; background: ${accent}15`}>
      <p class="text-xs mb-0.5" style={`color: ${accent}aa`}
         data-en="Your value" data-es="Tu valor">Your value</p>
      <p id="custom-total" class="text-xl font-bold text-white">$0.00</p>
    </div>
  </div>

  <!-- Main grid: Scenarios | Referral -->
  <div class="grid gap-4 lg:grid-cols-5">

    <!-- Scenarios -->
    <div class="lg:col-span-3 bg-gray-900 rounded-2xl overflow-hidden border border-gray-800">
      <!-- Colored top bar -->
      <div class="h-1 w-full" style={`background: linear-gradient(90deg, ${accent}, ${accent}44)`}></div>
      <div class="p-5">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4"
            data-en="Price scenarios" data-es="Escenarios de precio">Price scenarios</h2>
        <table class="w-full">
          <thead>
            <tr class="text-gray-600 text-xs uppercase border-b border-gray-800">
              <th class="text-left pb-2 pr-4" data-en="Scenario" data-es="Escenario">Scenario</th>
              <th class="text-right pb-2 pr-4" data-en="Price / pt" data-es="Precio / pt">Price / pt</th>
              <th class="text-right pb-2" data-en="Your value" data-es="Tu valor">Your value</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            {project.scenarios.map((s, i) => (
              <tr>
                <td class="py-3.5 pr-4 font-semibold text-white text-sm">
                  <span class="mr-2">{s.emoji}</span>
                  <span data-en={s.label} data-es={s.labelEs}>{s.label}</span>
                </td>
                <td class="py-3.5 pr-4 text-right text-gray-400 font-mono text-sm">
                  ${s.pricePerPoint.toFixed(2)}
                </td>
                <td id={`scenario-val-${i}`}
                  class={`py-3.5 text-right text-lg font-bold ${i===0?'text-red-400':i===1?'text-yellow-400':'text-green-400'}`}>
                  $0.00
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Referral + Tips -->
    <div class="lg:col-span-2 flex flex-col gap-3">
      <div class="rounded-2xl p-5 border flex-1" style={`border-color: ${accent}30; background: ${accent}12`}>
        <p class="text-xs font-semibold uppercase tracking-wider mb-1" style={`color: ${accent}`}
           data-en="Referral link" data-es="Link de referido">Referral link</p>
        <p class="text-white text-sm font-medium mb-4"
           data-en={project.referralBenefit} data-es={project.referralBenefitEs}>
          {project.referralBenefit}
        </p>
        <a href={project.referralLink} target="_blank" rel="noopener noreferrer"
          class="block text-center text-white font-bold py-2.5 rounded-xl transition-opacity hover:opacity-90"
          style={`background: ${accent}`}
          data-en={`Sign up on ${project.name} →`}
          data-es={`Regístrate en ${project.name} →`}>
          Sign up on {project.name} →
        </a>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4">
        <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider mb-2"
           data-en="Tips" data-es="Consejos">Tips</p>
        <ul class="space-y-1.5 text-gray-500 text-xs">
          <li data-en="• Stay active every day" data-es="• Mantén actividad constante">• Stay active every day</li>
          <li data-en="• Increase volume gradually" data-es="• Aumenta el volumen gradualmente">• Increase volume gradually</li>
          <li data-en="• Referral link = extra bonuses" data-es="• Link de referido = bonificaciones extra">• Referral link = extra bonuses</li>
          <li data-en="• Watch for season multipliers" data-es="• Atento a multiplicadores de temporada">• Watch for season multipliers</li>
        </ul>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ projectScenarios: project.scenarios, projectSliderMax: project.sliderMax }}>
  function fmt(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function update() {
    const pts = parseFloat(document.getElementById('my-points')?.value) || 0;
    const price = parseFloat(document.getElementById('custom-price')?.value) || 0;
    document.getElementById('custom-total').textContent = fmt(pts * price);
    projectScenarios.forEach((s, i) => {
      const el = document.getElementById(`scenario-val-${i}`);
      if (el) el.textContent = fmt(pts * s.pricePerPoint);
    });
  }
  const range = document.getElementById('custom-price-range');
  const price = document.getElementById('custom-price');
  range?.addEventListener('input', () => { price.value = range.value; update(); });
  price?.addEventListener('input', () => { range.value = Math.min(parseFloat(price.value)||0, projectSliderMax); update(); });
  document.getElementById('my-points')?.addEventListener('input', update);
</script>
