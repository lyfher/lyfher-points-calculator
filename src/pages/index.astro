---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { tools } from '../data/tools';
import ProjectLogo from '../components/ProjectLogo.astro';
---

<Layout title="Lyfher Points Calculator — Perpetuals Points Calculator">
  <!-- Hero -->
  <section class="text-center py-12">
    <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
      <span data-en="Points" data-es="Calculadora de">Points</span>
      <span class="text-blue-400" data-en=" Calculator" data-es=" Puntos"> Calculator</span>
    </h1>
    <p
      class="text-gray-400 text-lg max-w-xl mx-auto"
      data-en="Estimate how many points you're accumulating on the best protocols and maximize your airdrop rewards."
      data-es="Estima cuántos puntos estás acumulando en los mejores protocolos y maximiza tus recompensas."
    >
      Estimate how many points you're accumulating on the best protocols and maximize your airdrop rewards.
    </p>
  </section>

  <!-- Compare CTA -->
  <div class="flex justify-center mb-8">
    <a href="/compare"
       class="inline-flex items-center gap-2 bg-gray-900 border border-gray-700 hover:border-gray-500 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
      ⚖️ <span data-en="Compare all projects" data-es="Comparar todos los proyectos">Compare all projects</span>
      <span class="text-gray-500">→</span>
    </a>
  </div>

  <!-- Section label: Perpetuals -->
  <div class="flex items-center gap-3 mb-4">
    <span class="text-xs font-semibold uppercase tracking-widest text-gray-500" data-en="Perpetuals" data-es="Perpetuos">Perpetuals</span>
    <div class="flex-1 h-px bg-gray-800"></div>
  </div>

  <!-- Project Cards -->
  <section class="grid gap-6 sm:grid-cols-2">
    {projects.filter(p => p.slug !== 'treadfi').map((project) => (
      <a
        href={`/${project.slug}`}
        class="group block bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-gray-600 hover:bg-gray-800 transition-all duration-200"
      >
        <div class="flex items-center gap-3 mb-3">
          <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="md" />
          <h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">
            {project.name}
          </h2>
        </div>
        <p
          class="text-gray-400 text-sm leading-relaxed mb-4"
          data-en={project.description}
          data-es={project.descriptionEs}
        >
          {project.description}
        </p>
        <span
          class="text-blue-400 text-sm font-medium"
          data-en="Calculate points →"
          data-es="Calcular puntos →"
        >
          Calculate points →
        </span>
      </a>
    ))}

    <!-- More coming soon -->
    <div class="bg-gray-900/50 border border-dashed border-gray-800 rounded-2xl p-6 flex items-center justify-center">
      <p
        class="text-gray-600 text-sm text-center"
        data-en="🔜 More projects coming soon"
        data-es="🔜 Más proyectos próximamente"
      >
        🔜 More projects coming soon
      </p>
    </div>
  </section>

  <!-- Section label: Tools & Bots -->
  <div class="flex items-center gap-3 mt-10 mb-4">
    <span class="text-xs font-semibold uppercase tracking-widest text-gray-500" data-en="Tools & Bots" data-es="Herramientas y Bots">Tools & Bots</span>
    <div class="flex-1 h-px bg-gray-800"></div>
  </div>

  <section class="grid gap-6 sm:grid-cols-2">
    {tools.map((tool) => (
      <a
        href={tool.referralLink}
        target="_blank"
        rel="noopener noreferrer"
        class="group block bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-gray-600 hover:bg-gray-800 transition-all duration-200"
      >
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            {tool.logoSrc
              ? <img src={tool.logoSrc} alt={tool.name} class="w-10 h-10 rounded-xl object-cover" />
              : <span class="text-3xl">{tool.logoEmoji}</span>
            }
            <h2 class="text-xl font-bold text-white group-hover:transition-colors" style={`--hover-color: ${tool.accentHex}`}>
              {tool.name}
            </h2>
          </div>
          <span class="text-xs font-semibold px-2 py-1 rounded-lg border"
                style={`color: ${tool.accentHex}; border-color: ${tool.accentHex}40; background: ${tool.accentHex}12`}
                data-en={tool.tag} data-es={tool.tagEs}>
            {tool.tag}
          </span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-3"
           data-en={tool.description} data-es={tool.descriptionEs}>
          {tool.description}
        </p>
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium" style={`color: ${tool.accentHex}`}
                data-en={tool.referralBenefit} data-es={tool.referralBenefitEs}>
            {tool.referralBenefit} →
          </span>
          {tool.calculatorSlug && (
            <a href={`/${tool.calculatorSlug}`}
               class="text-xs text-gray-500 hover:text-gray-300 transition-colors"
               onclick="event.stopPropagation()"
               data-en="Calculate points →" data-es="Calcular puntos →">
              Calculate points →
            </a>
          )}
        </div>
      </a>
    ))}
  </section>

  <!-- About -->
  <section class="mt-10 border-t border-gray-800 pt-6 text-center">
    <p
      class="text-gray-600 text-sm max-w-xl mx-auto"
      data-en="Enter your points balance for any perpetuals protocol and instantly see their USD value across bear, base, and bull scenarios — then compare across projects to decide where to focus."
      data-es="Ingresa tu balance de puntos en cualquier protocolo de perpetuos y ve al instante su valor en USD en escenarios bajista, normal y optimista — luego compara entre proyectos para decidir dónde enfocarte."
    >
      Enter your points balance for any perpetuals protocol and instantly see their USD value across bear, base, and bull scenarios — then compare across projects to decide where to focus.
    </p>
  </section>
</Layout>
