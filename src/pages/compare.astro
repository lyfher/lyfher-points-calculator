---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import ProjectLogo from '../components/ProjectLogo.astro';

// All unique scenario labels (assume same across projects: Bear/Base/Bull)
const scenarioLabels = projects[0].scenarios.map(s => ({ label: s.label, labelEs: s.labelEs, emoji: s.emoji }));
---

<Layout
  title="Compare Projects — Lyfher Points Calculator"
  description="Compare the value of your points across all DeFi projects to decide what to farm."
>

  <div class="mb-6">
    <div class="flex items-center gap-3 mb-1">
      <a href="/" class="text-gray-600 hover:text-gray-400 text-sm transition-colors">←</a>
      <h1 class="text-2xl font-bold text-white"
          data-en="Compare Projects" data-es="Comparar Proyectos">Compare Projects</h1>
    </div>
    <p class="text-gray-500 text-sm ml-7"
       data-en="Enter your points for each project to see where your bag is worth the most."
       data-es="Ingresa tus puntos por proyecto para ver dónde vale más tu posición.">
      Enter your points for each project to see where your bag is worth the most.
    </p>
  </div>

  <!-- Points input per project -->
  <div class="grid gap-3 sm:grid-cols-2 mb-6">
    {projects.map((project) => (
      <div
        class="flex items-center gap-4 rounded-2xl p-4 border"
        style={`border-color: ${project.accentHex}30; background: ${project.accentHex}0e`}
      >
        <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="md" />
        <div class="flex-1">
          <div class="flex items-center justify-between mb-1">
            <label class="text-xs font-semibold" style={`color: ${project.accentHex}`}>
              {project.name}
            </label>
            <a
              href={project.referralLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-gray-600 hover:text-gray-300 transition-colors"
              title={project.referralBenefit}
            >
              Join ↗
            </a>
          </div>
          <input
            type="number"
            id={`pts-${project.slug}`}
            placeholder="0"
            min="0"
            max="1000000"
            class="w-full bg-gray-900/80 border border-gray-700 rounded-lg px-3 py-2 text-white font-bold placeholder-gray-700 focus:outline-none transition-colors text-sm"
            onfocus={`this.style.borderColor='${project.accentHex}80'`}
            onblur="this.style.borderColor=''"
            oninput="updateCompare()"
          />
        </div>
        <!-- $/pt reference -->
        <div class="text-right text-xs text-gray-600 space-y-0.5 hidden sm:block">
          {project.scenarios.map((s, i) => (
            <div class={i===0?'text-red-500/70':i===1?'text-yellow-500/70':'text-green-500/70'}>
              {s.emoji} ${s.pricePerPoint}/pt
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- More coming soon placeholder -->
    <div class="flex items-center justify-center rounded-2xl p-4 border border-dashed border-gray-800">
      <span class="text-gray-700 text-sm"
            data-en="🔜 More projects soon" data-es="🔜 Más proyectos pronto">🔜 More projects soon</span>
    </div>
  </div>

  <!-- Comparison table -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-4">
    <div class="p-5 border-b border-gray-800">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider"
          data-en="Value comparison by scenario" data-es="Comparación de valor por escenario">
        Value comparison by scenario
      </h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-800 text-xs text-gray-600 uppercase">
            <th class="text-left px-5 py-3" data-en="Project" data-es="Proyecto">Project</th>
            {scenarioLabels.map((s, i) => (
              <th class={`text-right px-4 py-3 ${i===0?'text-red-500/70':i===1?'text-yellow-500/70':'text-green-500/70'}`}>
                {s.emoji} <span data-en={s.label} data-es={s.labelEs}>{s.label}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          {projects.map((project) => (
            <tr class="group hover:bg-gray-800/50 transition-colors">
              <td class="px-5 py-4">
                <div class="flex items-center gap-2">
                  <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="sm" />
                  <a
                    href={project.referralLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-semibold text-white text-sm hover:underline decoration-gray-600 underline-offset-2 group/link"
                    title={project.referralBenefit}
                  >
                    {project.name}
                    <span class="text-gray-700 group-hover/link:text-gray-400 ml-1 text-xs">↗</span>
                  </a>
                </div>
              </td>
              {project.scenarios.map((s, i) => (
                <td id={`cmp-${project.slug}-${i}`}
                  class={`px-4 py-4 text-right font-bold text-base ${i===0?'text-red-400':i===1?'text-yellow-400':'text-green-400'}`}>
                  $0.00
                </td>
              ))}
            </tr>
          ))}
          <!-- Total row -->
          <tr class="bg-gray-800/60 border-t-2 border-gray-700">
            <td class="px-5 py-4 font-bold text-white text-sm"
                data-en="TOTAL" data-es="TOTAL">TOTAL</td>
            {scenarioLabels.map((_, i) => (
              <td id={`total-${i}`}
                class={`px-4 py-4 text-right font-bold text-lg ${i===0?'text-red-400':i===1?'text-yellow-400':'text-green-400'}`}>
                $0.00
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Best $/pt ranking -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4"
        data-en="Best $/point (base scenario)" data-es="Mejor $/punto (escenario normal)">
      Best $/point (base scenario)
    </h2>
    <div class="space-y-2">
      {[...projects]
        .sort((a, b) => b.scenarios[1].pricePerPoint - a.scenarios[1].pricePerPoint)
        .map((project, rank) => (
          <div class="flex items-center gap-3">
            <span class="text-sm w-5 text-gray-600 font-mono">{rank === 0 ? '🥇' : rank === 1 ? '🥈' : '🥉'}</span>
            <ProjectLogo logoSrc={project.logoSrc} logoEmoji={project.logoEmoji} name={project.name} size="sm" />
            <span class="text-white text-sm font-medium flex-1">{project.name}</span>
            <div class="flex gap-3 text-xs">
              {project.scenarios.map((s, i) => (
                <span class={i===0?'text-red-400/70':i===1?'text-yellow-400':'text-green-400/70'}>
                  {s.emoji} ${s.pricePerPoint}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>

</Layout>

<script define:vars={{ projectsData: projects.map(p => ({ slug: p.slug, scenarios: p.scenarios })) }}>
  function fmt(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function updateCompare() {
    const scenarioCount = projectsData[0].scenarios.length;
    const totals = new Array(scenarioCount).fill(0);

    projectsData.forEach(project => {
      const pts = Math.min(parseFloat(document.getElementById(`pts-${project.slug}`)?.value) || 0, 1000000);
      project.scenarios.forEach((s, i) => {
        const val = pts * s.pricePerPoint;
        totals[i] += val;
        const el = document.getElementById(`cmp-${project.slug}-${i}`);
        if (el) el.textContent = fmt(val);
      });
    });

    totals.forEach((t, i) => {
      const el = document.getElementById(`total-${i}`);
      if (el) el.textContent = fmt(t);
    });
  }

  // Make available globally for inline oninput handlers
  window.updateCompare = updateCompare;
</script>
